<!-- snippets/subscription-widget-grid.liquid -->
{% comment %}
  Grid widget style - exact replica of React renderOptions grid case
{% endcomment %}

<div style="padding-top: 8px;">
  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: {{ widget_customization.optionSpacing | default: 8 }}px;" role="radiogroup" aria-label="Purchase options">
    <!-- One-time purchase box -->
    <div role="radio" aria-checked="false" tabindex="0" style="display: flex; flex-direction: column; align-items: center; justify-content: center; border-radius: {{ widget_customization.borderRadius | default: 12 }}px; border: {{ widget_customization.borderWidth | default: 1 }}px solid #e5e7eb; padding: 12px; cursor: pointer; background-color: white; color: black;">
      <span style="font-size: 14px; font-weight: 300; text-align: center;">
        {{ widget_labels.oneTimePurchaseLabel | default: 'One-time purchase' }}
      </span>
      <span style="font-size: 14px;">
        {{ shop.currency }}{{ productPreview.options[0].price }}
      </span>
    </div>

    <!-- Subscription frequencies -->
    {% for freq in frequency_options %}
      <div role="radio" aria-checked="false" tabindex="0" style="display: flex; flex-direction: column; align-items: center; justify-content: center; border-radius: {{ widget_customization.borderRadius | default: 12 }}px; border: {{ widget_customization.borderWidth | default: 1 }}px solid #e5e7eb; padding: 12px; cursor: pointer; background-color: white; color: black;">
        <span style="font-size: {{ widget_customization.labelTextSize | default: 14 }}px; font-weight: 300; text-align: center;">
          {{ freq.label }}
        </span>
        <span style="font-size: 14px;">
          {% comment %} {{ shop.currency }}{{ productPreview.options[0].price | times: (1 - freq.discount / 100) | money_without_currency }} {% endcomment %}
        </span>
        <span style="font-size: 12px;">({{ freq.discount }}% off)</span>
      </div>
    {% endfor %}
  </div>
</div>